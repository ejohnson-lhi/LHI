# ==========================================================================
# Lighthouse Inn AI Reservation Agent — Backend Environment Configuration
# Copy this file to .env and fill in real values. NEVER commit .env to version control.
# ==========================================================================

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Twilio ---
# Account SID and Auth Token from console.twilio.com
TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
# The hotel's main phone number (Twilio-owned after porting; +E.164 format)
TWILIO_HOTEL_NUMBER=+15412286786
# The hotel's toll-free number (also Twilio-owned)
TWILIO_TOLLFREE_NUMBER=+18005551234
# Optional Messaging Service SID for A2P 10DLC-registered SMS. Starts with MG.
# Once set, all sends route through the Messaging Service instead of using
# From=TWILIO_HOTEL_NUMBER directly. Required for compliant US A2P traffic.
TWILIO_MESSAGING_SERVICE_SID=

# --- Cloudbeds ---
# API key from Cloudbeds; property ID for The Lighthouse Inn
CLOUDBEDS_API_KEY=your_cloudbeds_api_key_here
CLOUDBEDS_PROPERTY_ID=your_property_id_here
# User ID of the "Iris Agent" Cloudbeds user (so notes get attributed to her,
# not the API key owner). Find via GET /admin/cloudbeds_users.
CLOUDBEDS_IRIS_USER_ID=
# Reservation sourceID to tag new bookings (e.g., "s-1183685" for Voice AI).
# Find via GET /admin/cloudbeds_sources.
CLOUDBEDS_RESERVATION_SOURCE_ID=

# --- Anthropic (for ancillary backend tasks like call summarization, NOT for the voice agent —
#                that's configured separately in Vapi) ---
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# --- Stripe (used via Twilio Pay Connector for card capture; same Stripe account as Cloudbeds) ---
STRIPE_API_KEY=sk_test_your_stripe_key_here

# --- Vapi (for triggering outbound calls and managing the assistant config) ---
VAPI_API_KEY=your_vapi_api_key_here
VAPI_ASSISTANT_ID=your_assistant_id_here

# --- Database ---
# Default: local SQLite file. Switch to postgres URL when deploying to DigitalOcean.
DATABASE_URL=sqlite+aiosqlite:///./data/lighthouse.db

# --- Admin auth ---
# The shared secret the ATA injects as the X-Hotel-Auth SIP header.
# Generate a long random string: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SIP_HEADER_SECRET=change-me-to-a-random-secret

# --- Eric's contact ---
ERIC_CELL_NUMBER=+15412286786
