{
  "dispatchRule": {
    "name": "iris-dispatch",
    "trunkIds": ["ST_REPLACE_WITH_REAL_TRUNK_ID"],
    "rule": {
      "dispatchRuleIndividual": {
        "roomPrefix": "iris-call-"
      }
    },
    "roomConfig": {
      "egress": {
        "tracks": {
          "filepath": "/out/{room_name}-{track_id}-{time}.ogg"
        }
      }
    }
  }
}
