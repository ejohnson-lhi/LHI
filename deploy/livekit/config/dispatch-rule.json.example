{
  "dispatchRule": {
    "name": "iris-dispatch",
    "trunkIds": ["ST_REPLACE_WITH_REAL_TRUNK_ID"],
    "rule": {
      "dispatchRuleIndividual": {
        "roomPrefix": "iris-call-"
      }
    },
    "roomConfig": {
      "egress": {
        "participant": {
          "fileOutputs": [
            {
              "fileType": "OGG",
              "filepath": "/out/{room_name}_{publisher_identity}_{time}.ogg"
            }
          ]
        }
      }
    }
  }
}
