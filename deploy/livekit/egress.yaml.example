# Copy to egress.yaml and fill in real values. egress.yaml is gitignored.
#
# api_key/api_secret must match the entry in livekit.yaml's `keys:` map.
# Egress runs on host networking (see docker-compose.yml) so it reaches
# Redis and LiveKit at 127.0.0.1 like the other services.

api_key: APIxxxxxxxxxxxxxx
api_secret: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ws_url: ws://127.0.0.1:7880
insecure: true  # because we use ws:// not wss:// for the local LiveKit

redis:
  address: 127.0.0.1:6379

log_level: info

# Intentionally NOT setting a `storage:` block — that triggers cloud upload
# (S3/GCP/Azure). Omitting it = local-disk-only mode. Egress writes directly
# to the path passed in `RoomCompositeEgressRequest.file_outputs[].filepath`,
# which is `/out/...` per our SIP dispatch rule. `/out` is volume-mounted to
# /opt/iris-backend/recordings on the host (see docker-compose.yml).
