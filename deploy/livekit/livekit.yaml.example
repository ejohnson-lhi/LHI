# Copy to livekit.yaml and fill in real key/secret. livekit.yaml is gitignored.
# Generate fresh keys (one-time):
#   LK_KEY="API$(openssl rand -hex 8)"
#   LK_SECRET="$(openssl rand -hex 32)"

port: 7880
bind_addresses:
  - "0.0.0.0"

rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 50100
  use_external_ip: true

redis:
  address: 127.0.0.1:6379

keys:
  APIxxxxxxxxxxxxxx: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Allow the server admin API to remotely UN-mute a participant's track.
# Required by the Iris agent's capture_card_dtmf flow: it mutes the caller's
# audio track during DTMF card capture (to keep tones out of the egress
# recording), then needs to un-mute on completion. Without this, the un-mute
# call fails with TwirpError "remote unmute not enabled" and the caller
# stays muted for the rest of the call. The privacy concern this flag exists
# for (admins surreptitiously enabling someone's mic) doesn't apply here —
# we're undoing our OWN mute, not enabling a mic that was off when the call
# started.
room:
  enable_remote_unmute: true

logging:
  level: info
