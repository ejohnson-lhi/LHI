# Copy to livekit.yaml and fill in real key/secret. livekit.yaml is gitignored.
# Generate fresh keys (one-time):
#   LK_KEY="API$(openssl rand -hex 8)"
#   LK_SECRET="$(openssl rand -hex 32)"

port: 7880
bind_addresses:
  - "0.0.0.0"

rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 50100
  use_external_ip: true

redis:
  address: 127.0.0.1:6379

keys:
  APIxxxxxxxxxxxxxx: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

logging:
  level: info
