# Copy to .env and fill in real values. .env is gitignored.

# Self-hosted LiveKit on the droplet — these come from /opt/livekit/livekit.yaml.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key — same one used by backend/.env.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Deepgram API key — from https://console.deepgram.com (free tier $200 credit).
DEEPGRAM_API_KEY=...
