# --- Python ---
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.ruff_cache/

# --- Secrets and local state ---
backend/.env
agent/.env
.env
backend/data/
recordings/

# --- LiveKit stack: real configs and trunk/dispatch JSON have secrets or
# environment-specific IDs. Templates (*.example) are checked in.
deploy/livekit/livekit.yaml
deploy/livekit/sip.yaml
deploy/livekit/egress.yaml
deploy/livekit/config/inbound-trunk.json
deploy/livekit/config/dispatch-rule.json
deploy/livekit/config/outbound-trunk.json
deploy/livekit/config/frontdesk-outbound-trunk.json

# --- Local-only Windows binaries ---
backend/cloudflared-windows-amd64.exe

# --- Kokoro TTS model files (large, downloaded on each environment) ---
agent/models/

# --- HeySadie exported data (large, not deployed; kept locally only) ---
tools/heysadie_export/exports/
tools/heysadie_export/.venv/
tools/heysadie_export/session.json
tools/heysadie_export/.last_export_dir

# --- Imported HeySadie reference data (large media + dump) ---
HeySadie Data/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Twilio compliance / status exports (filenames contain Account SID,
# triggering GitHub push protection; not source anyway) ---
SMS-AC*.csv

# --- Twilio Console exports (saved web pages, reference only) ---
Voice _ Twilio Console-*.htm
Voice _ Twilio Console-*_files/

# --- Grandstream HT802 reference docs (saved web pages + zipped firmware) ---
HT802V2*.htm
HT802V2*_files/
HT802V2*/
Release_HT80xV2_*.zip
Release_HT80xV2_*/

# --- Packet captures (debugging only, large binaries) ---
capture-*.tgz
capture*.tgz

# --- TTS A/B testing artifacts (large model + voice files, generated audio).
# Scripts in tools/tts_ab/*.py ARE tracked; outputs and model blobs are not.
tools/tts_ab/kokoro-v1.0.onnx
tools/tts_ab/voices-v1.0.bin
tools/tts_ab/output/
tools/tts_ab/iris_snapshot.json

# --- Deploy helper: next-commit message written by Claude, consumed by
# deploy.bat. Local only - each commit's actual message lands in git history.
tools/.deploy_msg

# --- Deploy helper: local-only env var values (smoke test config etc.),
# SCP'd by deploy.bat to the droplet and merged into backend/.env via
# tools/sync_deploy_env.sh. Mirrors the .deploy_msg pattern. The
# .template version is committed so the structure is discoverable.
tools/.deploy_env
